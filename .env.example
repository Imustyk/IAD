# =============================================================================
# IAD platform — environment file template.
# Copy this file to `.env` and override values per environment.
# All variables MUST be prefixed with IAD_ (see iad/config/settings.py).
# =============================================================================

# -- Identity ---------------------------------------------------------------
IAD_ENVIRONMENT=development         # development | staging | production | test
IAD_DEBUG=true

# -- Logging ----------------------------------------------------------------
IAD_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
IAD_LOG_JSON=false                  # set to true in production for log shippers
IAD_LOG_RETENTION_DAYS=30
IAD_LOG_MAX_BYTES=10485760          # 10 MiB
IAD_LOG_BACKUP_COUNT=10

# -- Upload limits ----------------------------------------------------------
IAD_MAX_UPLOAD_MB=200
IAD_MAX_ROWS=5000000
IAD_MAX_COLUMNS=10000

# -- ML defaults ------------------------------------------------------------
IAD_DEFAULT_RANDOM_SEED=42
IAD_DEFAULT_TEST_SIZE=0.2
IAD_DEFAULT_CV_FOLDS=5
IAD_MAX_TRAINING_TIME_SECONDS=1800

# -- Security & auth (Phase 7) ----------------------------------------------
# MUST be overridden in production with a strong, secret value.
# Generate via:  python -c "import secrets; print(secrets.token_urlsafe(64))"
IAD_SECRET_KEY=change-me-in-production
IAD_SESSION_TTL_MINUTES=480
# IAD_AUTH_ENABLED=false
# IAD_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# IAD_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# IAD_CSRF_ENABLED=true
# IAD_RATE_LIMIT_REQUESTS=100
# IAD_RATE_LIMIT_WINDOW_SECONDS=60
# IAD_CORS_ORIGINS=["http://localhost:8501","http://localhost:8000"]

# -- Performance (Phase 8) --------------------------------------------------
# IAD_PERF_USE_POLARS=true
# IAD_PERF_USE_DASK=true
# IAD_PERF_DASK_THRESHOLD_ROWS=100000
# IAD_PERF_LAZY_PREVIEW_ROWS=5000
# IAD_PERF_BACKGROUND_TRAINING=true
# IAD_PERF_MAX_WORKERS=2

# -- Database (Phase 6) -----------------------------------------------------
# Default (no URL): SQLite file at data/iad.db
# IAD_DATABASE_URL=postgresql+psycopg://iad:iad@localhost:5432/iad
# IAD_DATABASE_ENABLED=false
# IAD_DATABASE_ECHO=false
# IAD_AUTO_CREATE_DB=false

# -- Observability (Phase 12) -----------------------------------------------
# IAD_METRICS_ENABLED=true
# IAD_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# IAD_SENTRY_ENABLED=true
# IAD_SENTRY_TRACES_SAMPLE_RATE=0.1
# IAD_SENTRY_PROFILES_SAMPLE_RATE=0.0

# -- Optional integrations --------------------------------------------------
# IAD_MLFLOW_TRACKING_URI=http://localhost:5000

# -- Docker observability profile (host ports) --------------------------------
# IAD_PROMETHEUS_PORT=9090
# IAD_GRAFANA_PORT=3000

# -- Docker Compose (Phase 10) -----------------------------------------------
# Used by docker-compose.yml (host-side overrides).
# IAD_POSTGRES_USER=iad
# IAD_POSTGRES_PASSWORD=iad
# IAD_POSTGRES_DB=iad
# IAD_POSTGRES_PORT=5432
# IAD_STREAMLIT_PORT=8501
# IAD_API_PORT=8000
# IAD_HTTP_PORT=80
# IAD_RUN_MIGRATIONS=true          # api container: alembic upgrade head on start
